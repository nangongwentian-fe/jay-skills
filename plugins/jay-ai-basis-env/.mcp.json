{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest",
        "--autoConnect"
      ]
    },
    "context7": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "-lc",
        "npx -y @upstash/context7-mcp --api-key \"$CONTEXT7_API_KEY\""
      ]
    },
    "exa": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "-lc",
        "EXA_API_KEY=\"$EXA_API_KEY\" npx -y exa-mcp-server@latest"
      ]
    }
  }
}
